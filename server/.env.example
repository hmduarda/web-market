# =============================================
# Servidor
# =============================================
PORT=5000

# =============================================
# MongoDB Atlas
# Substitua <user>, <password> e <cluster> pelos seus dados
# Exemplo: mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/web-market?retryWrites=true&w=majority
# =============================================
DB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/supermercado?retryWrites=true&w=majority

# =============================================
# JWT
# =============================================
JWT_SECRET=sua_chave_secreta_muito_segura_aqui
